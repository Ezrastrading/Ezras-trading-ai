# Copy to .env and fill in. Never commit .env.

# --- Required for AI briefs ---
OPENAI_API_KEY=

# --- Polymarket (defaults work; override if needed) ---
# POLYMARKET_GAMMA_BASE=https://gamma-api.polymarket.com

# --- Information intake (optional but recommended) ---
TAVILY_API_KEY=
FIRECRAWL_API_KEY=

# GPT Researcher: optional; not bundled. Use the versioned wrapper in this repo (chmod +x).
# Expects gptr-venv and gpt-researcher-repo as siblings of the trading-ai/ folder (see README).
# GPT_RESEARCHER_ENABLED=false → no subprocess, no logs.
# GPT_RESEARCHER_ENABLED=true → set GPT_RESEARCHER_COMMAND to scripts/gptr-run.sh (absolute path if parents contain spaces).
# Example after: cd trading-ai && chmod +x scripts/gptr-run.sh
# GPT_RESEARCHER_COMMAND="/.../trading-ai/scripts/gptr-run.sh"
GPT_RESEARCHER_ENABLED=false
GPT_RESEARCHER_COMMAND=

# --- Alerts (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Filters (Phase 1 defaults — override in .env) ---
MIN_VOLUME_USD=5000
MAX_DAYS_TO_EXPIRY=60
MIN_IMPLIED_PROB=0.10
MAX_IMPLIED_PROB=0.90
REQUIRE_IMPLIED_PROBABILITY=true
MARKETS_FETCH_LIMIT=200
MAX_CANDIDATES_PER_RUN=10

# High-signal alerts only (1–10)
ALERT_MIN_SIGNAL_SCORE=7

# Data directory (SQLite + relative paths)
DATA_DIR=data

# Scheduler: set to run `trading-ai schedule` (minutes between runs)
# SCHEDULE_INTERVAL_MINUTES=60
