# Copy to .env and fill in. Never commit .env.

# --- Required for AI briefs ---
OPENAI_API_KEY=

# --- Polymarket (defaults work; override if needed) ---
# POLYMARKET_GAMMA_BASE=https://gamma-api.polymarket.com

# --- Information intake (optional but recommended) ---
TAVILY_API_KEY=
FIRECRAWL_API_KEY=

# GPT Researcher: optional subprocess hook (disabled by default)
GPT_RESEARCHER_ENABLED=false
# GPT_RESEARCHER_COMMAND=gpt-researcher

# --- Alerts (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Filters ---
MIN_VOLUME_USD=10000
MAX_DAYS_TO_EXPIRY=90
MIN_IMPLIED_PROB=0.05
MAX_IMPLIED_PROB=0.95
REQUIRE_IMPLIED_PROBABILITY=true
MARKETS_FETCH_LIMIT=200
MAX_CANDIDATES_PER_RUN=5

# High-signal alerts only (1–10)
ALERT_MIN_SIGNAL_SCORE=7

# Data directory (SQLite + relative paths)
DATA_DIR=data

# Scheduler: set to run `trading-ai schedule` (minutes between runs)
# SCHEDULE_INTERVAL_MINUTES=60
