{
  "schema": "storage_path_map_v1",
  "EZRAS_RUNTIME_ROOT": "<required session root — all paths below are relative unless noted>",
  "paths": {
    "nte_memory_trade_memory_json": "shark/nte/memory/trade_memory.json",
    "nte_memory_other": "shark/nte/memory/*.json (strategy_scores, goals_state, etc.)",
    "global_review_packet_latest": "shark/memory/global/review_packet_latest.json",
    "global_joint_review_latest": "shark/memory/global/joint_review_latest.json",
    "global_review_scheduler_ticks_jsonl": "shark/memory/global/review_scheduler_ticks.jsonl",
    "global_claude_gpt_latest": "shark/memory/global/claude_review_latest.json, gpt_review_latest.json",
    "governance_gate_decisions_log": "governance_gate_decisions.log (file at runtime root)",
    "databank_trade_events_jsonl": "<TRADE_DATABANK_MEMORY_ROOT or EZRAS_RUNTIME_ROOT/databank>/trade_events.jsonl",
    "first_20_shadow_archives": "first_20_sessions/<session_id>/ (shadow harness)",
    "live_first_20_archives": "live_first_20_sessions/<session_id>/ (operator live preflight/session)",
    "shark_state_json": "shark/state/*.json (capital, positions, etc.)",
    "shark_audit_jsonl": "shark/logs/shark_audit.jsonl"
  },
  "resolution_rules": {
    "databank": "TRADE_DATABANK_MEMORY_ROOT else EZRAS_RUNTIME_ROOT/databank; else DatabankRootUnsetError",
    "nte_memory": "trading_ai.nte.paths.nte_memory_dir() → EZRAS_RUNTIME_ROOT/shark/nte/memory",
    "global_memory": "trading_ai.governance.storage_architecture.global_memory_dir() → EZRAS_RUNTIME_ROOT/shark/memory/global"
  }
}
