EZRAS_RUNTIME_ROOT=~/ezras-runtime
# Claude trade evaluator (optional — Gate 5b before venue execution)
ANTHROPIC_API_KEY=
# Optional override; default claude-sonnet-4-20250514
ANTHROPIC_MODEL=
# false = live venue orders (Kalshi, Manifold, …). true = audit-only stub (no submit).
EZRAS_DRY_RUN=false
# Optional RSS cap in MB. Leave unset — a fixed 512MB cap caused ENOMEM during HTTPS on small dynos.
SHARK_RLIMIT_MB=
# Extra Polymarket-only 30s job (heavy). Kalshi HF already runs every 30s — keep false unless needed.
CRYPTO_SCALP_SCAN_ENABLED=false
# Remote deploy (Railway / VPS): optional state mirror + health port
SUPABASE_URL=
SUPABASE_KEY=
GITHUB_GIST_TOKEN=
PORT=8080
RAILWAY_ENVIRONMENT=
# POLY_WALLET_KEY: optional for US operators — Polymarket blocks US execution. Leave empty if US-based.
POLY_WALLET_KEY=
POLY_API_KEY=
POLY_CLOB_BASE=https://clob.polymarket.com
# false (default): never submit Polymarket orders. true: still geo_blocked (US).
POLY_EXECUTION_ENABLED=false
# Kalshi HF daemon: 30s / 60s jobs when true (see run_shark + scheduler).
KALSHI_HF_ENABLED=true
# Max concurrent Kalshi positions (HV cap also uses KALSHI_HV_MAX_OPEN_POSITIONS; code defaults 12 / 8).
# Higher values = more parallel Kalshi exposure (ensure balance covers max notional).
KALSHI_MAX_OPEN_POSITIONS=40
KALSHI_HV_MAX_OPEN_POSITIONS=12
# Active-pool size: markets scored per Kalshi fetch (see kalshi_limits.py).
# Raise (e.g. 600) if Tier_A>0 in candidates_after_filters_pre_sort but Tier_A=0 in active_pool_after_top_n.
KALSHI_FETCH_TOP_N=600
KALSHI_SERIES_MERGE_CAP=180
KALSHI_MARKETS_API_BATCH_LIMIT=200
KALSHI_FETCH_MARKETS_OPEN_LIMIT=500
KALSHI_OPEN_FALLBACK_SLICE=200
# Near-resolution HV: expiry windows (minutes, comma-separated min,max). Priority A > B > C.
KALSHI_TIER_A=5,10
KALSHI_TIER_B=10,30
KALSHI_TIER_C=30,60
KALSHI_TIER_PRIORITY=A,B,C
# Tier-C HV only if no A/B in batch OR edge beats best A/B by this margin (edge_after_fees scale).
KALSHI_TIER_C_MIN_EDGE_ADVANTAGE=0.02
# Doctrine / anti_forced_trade minimum edge for Kalshi NEAR_RESOLUTION_HV (idle/DD wideners apply on top).
KALSHI_TIER_A_MIN_EDGE=0.0080
KALSHI_TIER_B_MIN_EDGE=0.0150
KALSHI_TIER_C_MIN_EDGE=0.0200
KALSHI_MAX_POSITION_USD=500.00
KALSHI_MIN_POSITION_USD=1.00
# Top scored markets per batch toward execution (5–40, default 15 in code).
SCAN_TOP_PER_BATCH=30
# Kalshi: use KALSHI_ACCESS_KEY_ID + PEM in KALSHI_API_KEY (see docs), or legacy Bearer token in KALSHI_API_KEY.
KALSHI_ACCESS_KEY_ID=
KALSHI_API_KEY=
# HV near-resolution: aggressive_limit crosses spread (best ask + N cents); market = venue market order.
KALSHI_HV_ORDER_MODE=aggressive_limit
KALSHI_HV_LIMIT_BUMP_CENTS=2
# KALSHI_HV_TIME_IN_FORCE=immediate_or_cancel
MANIFOLD_API_KEY=
MANIFOLD_API_BASE=https://api.manifold.markets/v0
# Manifold is play-money (mana) unless true: no live orders unless MANIFOLD_REAL_MONEY=true; treasury USD uses same flag.
MANIFOLD_REAL_MONEY=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
STARTING_CAPITAL=25.00
FRED_API_KEY=
SHARK_TZ=UTC
# Treasury tracking — operator wallet for profit withdrawal
MASTER_WALLET_ADDRESS=
MASTER_WALLET_PLATFORM=coinbase
MASTER_WALLET_NETWORK=polygon
MASTER_WALLET_USDC_TARGET_PCT=60
MASTER_WALLET_ETH_TARGET_PCT=40
WITHDRAWAL_ALERT_THRESHOLD=5000
# Strategy toggles (Beast — optional extra fetchers)
STRATEGY_CRYPTO_ENABLED=true
STRATEGY_STOCKS_ENABLED=true
STRATEGY_OPTIONS_ENABLED=true
STRATEGY_PREDICTION_ENABLED=true
# Coinbase Advanced Trade API (for USDC/ETH balance tracking + optional execution)
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_WALLET_ADDRESS=
# Set true only when ready to route ``execution_live`` market orders through Coinbase.
COINBASE_EXECUTION_ENABLED=false
# Metaculus (API token required — public api2 listing is auth-gated as of 2025+)
METACULUS_API_TOKEN=
METACULUS_FETCH_ENABLED=true
# Robinhood (robin_stocks — optional; execution gated)
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=
ROBINHOOD_MFA_CODE=
ROBINHOOD_EXECUTION_ENABLED=false
# Options platforms — semi-automated, long options only
TASTYTRADE_USERNAME=
TASTYTRADE_PASSWORD=
TASTYTRADE_ACCOUNT_ID=
TASTYTRADE_EXECUTION_ENABLED=false
WEBULL_API_KEY=
WEBULL_ACCOUNT_ID=
# Sports betting budget (manual execution only — NY law)
SPORTS_DAILY_BUDGET=
