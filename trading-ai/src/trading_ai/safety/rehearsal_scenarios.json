{
  "truth_version": "kill_switch_rehearsal_scenarios_v1",
  "kill_switch_scenarios": [
    {
      "id": "ks_runtime_inconsistency",
      "description": "Simulated daemon runtime consistency failure should trip halt and block execution.",
      "trigger_code": "RUNTIME_CONSISTENCY_FAILURE",
      "setup": "write_inconsistent_daemon_consistency_truth"
    },
    {
      "id": "ks_order_failure_loop",
      "description": "Repeated order failures should activate REPEATED_EXECUTION_FAILURE_LOOP.",
      "trigger_code": "REPEATED_EXECUTION_FAILURE_LOOP",
      "setup": "notify_order_failure_threshold"
    },
    {
      "id": "ks_supabase_failure",
      "description": "Supabase/databank write threshold breach halts with canonical code.",
      "trigger_code": "SUPABASE_DATABANK_WRITE_FAILURE_THRESHOLD",
      "setup": "activate_supabase_threshold"
    },
    {
      "id": "ks_stale_halt_truth",
      "description": "Mismatch between engine truth and system kill switch JSON fails closed.",
      "trigger_code": "STALE_INVALID_HALT_TRUTH",
      "setup": "desync_kill_switch_layers"
    },
    {
      "id": "ks_lock_exclusivity",
      "description": "Lock exclusivity breach recorded as halt (simulated).",
      "trigger_code": "LOCK_EXCLUSIVITY_VIOLATION",
      "setup": "activate_lock_breach"
    },
    {
      "id": "ks_slippage_spike",
      "description": "Extreme slippage trigger halts entries.",
      "trigger_code": "EXTREME_SLIPPAGE_THRESHOLD",
      "setup": "activate_slippage"
    },
    {
      "id": "ks_corrupted_artifact",
      "description": "Corrupt kill_switch_truth JSON fails closed on read.",
      "trigger_code": "CORRUPTED_STATE_ARTIFACTS",
      "setup": "corrupt_truth_file"
    }
  ],
  "recovery_scenarios": [
    {
      "id": "rc_immediate_no_operator",
      "expect_ok": false,
      "operator_confirmed": false,
      "resume_mode": "supervised",
      "description": "Immediate recovery without operator confirm must fail."
    },
    {
      "id": "rc_partial_fix",
      "expect_ok": false,
      "operator_confirmed": true,
      "resume_mode": "supervised",
      "description": "Partial fix (inconsistent consistency truth) must fail even with operator confirm.",
      "leave_inconsistent_consistency": true
    },
    {
      "id": "rc_full_fix_supervised",
      "expect_ok": true,
      "operator_confirmed": true,
      "resume_mode": "supervised",
      "description": "Full validation + operator confirm clears halt; supervised resume only first."
    },
    {
      "id": "rc_autonomous_without_proof",
      "expect_ok": false,
      "operator_confirmed": true,
      "resume_mode": "autonomous",
      "description": "Autonomous resume must fail without daemon authority proof."
    }
  ]
}
