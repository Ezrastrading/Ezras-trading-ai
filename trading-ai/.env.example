# Copy to .env and fill in. Never commit .env.

# --- Required for AI briefs ---
OPENAI_API_KEY=

# --- Polymarket (defaults work; override if needed) ---
# POLYMARKET_GAMMA_BASE=https://gamma-api.polymarket.com

# --- Information intake (optional but recommended) ---
TAVILY_API_KEY=
FIRECRAWL_API_KEY=

# GPT Researcher: optional; not bundled. Use the versioned wrapper in this repo (chmod +x).
# Expects gptr-venv and gpt-researcher-repo as siblings of the trading-ai/ folder (see README).
# GPT_RESEARCHER_ENABLED=false → no subprocess, no logs.
# GPT_RESEARCHER_ENABLED=true → set GPT_RESEARCHER_COMMAND to scripts/gptr-run.sh (absolute path if parents contain spaces).
# Example after: cd trading-ai && chmod +x scripts/gptr-run.sh
# GPT_RESEARCHER_COMMAND="/.../trading-ai/scripts/gptr-run.sh"
GPT_RESEARCHER_ENABLED=false
GPT_RESEARCHER_COMMAND=

# --- Alerts (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Filters (Phase 1 defaults — override in .env) ---
MIN_VOLUME_USD=5000
MAX_DAYS_TO_EXPIRY=60
MIN_IMPLIED_PROB=0.10
MAX_IMPLIED_PROB=0.90
REQUIRE_IMPLIED_PROBABILITY=true
MARKETS_FETCH_LIMIT=200
MAX_CANDIDATES_PER_RUN=10

# High-signal alerts only (1–10)
ALERT_MIN_SIGNAL_SCORE=7

# Data directory (SQLite + relative paths)
DATA_DIR=data

# Scheduler: set to run `trading-ai schedule` (minutes between runs)
# SCHEDULE_INTERVAL_MINUTES=60

# ── Coinbase Advanced Trade — 24/7 spot crypto accumulation ──────────────────
# Get API keys at: https://portal.cdp.coinbase.com/access/api
# Key format: organizations/{org_id}/apiKeys/{key_id}
COINBASE_ENABLED=false
COINBASE_API_KEY_NAME=organizations/xxx/apiKeys/yyy
COINBASE_API_PRIVATE_KEY=-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----

# Per-instrument budgets (USD)
COINBASE_BTC_BUDGET=100
COINBASE_ETH_BUDGET=100
COINBASE_SOL_BUDGET=50

# Hard limits
COINBASE_MAX_TOTAL_USD=500
COINBASE_MAX_DAILY_LOSS=50
COINBASE_MAX_OPEN_POSITIONS=10
COINBASE_MIN_ORDER_USD=5.00
# Delta-neutral scalping defaults (override per deploy)
COINBASE_PROFIT_TARGET_PCT=0.00015
COINBASE_MIN_PROFIT_USD=0.015
COINBASE_STOP_LOSS_PCT=0.00012
COINBASE_TIME_STOP_MIN=3
COINBASE_HEDGE_ENABLED=true
COINBASE_HEDGE_TRIGGER_PCT=0.00008
COINBASE_GATE_E_ENABLED=false
COINBASE_GATE_E_POSITIONS=10
COINBASE_GATE_E_RSI_LO=40
COINBASE_GATE_E_RSI_HI=60

# Strategy B — grid trading
COINBASE_GRID_ENABLED=true
COINBASE_GRID_STEP_USD=500
COINBASE_GRID_ORDER_USD=25

# Strategy C — momentum scalp
COINBASE_MOMENTUM_ENABLED=true
