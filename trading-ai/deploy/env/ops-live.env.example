# OPERATOR: production path uses the committed stock template (no secrets):
#   deploy/env/ops-live.micro.template  →  install via:
#   sudo bash scripts/server/activate_micro_live_stack.sh
#
# For a hand-rolled file, copy to /opt/ezra-runtime/env/ops-live.env and chmod 600.
# Coinbase keys stay out of git (e.g. /opt/ezra-runtime/env/secrets.env sourced by the activate script).

# EZRAS_FULL_AUTONOMY_MODE=FULL_AUTONOMY_ACTIVE
# NTE_EXECUTION_MODE=live
# NTE_LIVE_TRADING_ENABLED=true
# COINBASE_ENABLED=true
# COINBASE_EXECUTION_ENABLED=true
# NTE_PAPER_MODE=false
# NTE_DRY_RUN=false
