# Example — remote Supabase sync + local artifact chain (copy to .env and fill secrets).
# Set SUPABASE_KEY for databank upserts (same value as service role is OK).

EZRAS_RUNTIME_ROOT=/path/to/persistent/ezras_runtime
TRADE_DATABANK_MEMORY_ROOT=${EZRAS_RUNTIME_ROOT}/databank

SUPABASE_URL=https://<project>.supabase.co
SUPABASE_KEY=<supabase_jwt_anon_or_service_role>
# Optional duplicate for tools that read SERVICE_ROLE only:
# SUPABASE_SERVICE_ROLE_KEY=<same_or_service_role>

# Do not use LIVE_FIRST_20_LOCAL_FIRST_OK when requiring remote sync for preflight —
# use SUPABASE_URL + key so live_first_20_operator check 9 passes as remote.

# Coinbase (placeholders)
# COINBASE_API_KEY_NAME=organizations/<org>/apiKeys/<key_id>
# COINBASE_API_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----\n"

COINBASE_ENABLED=true
NTE_EXECUTION_MODE=live
LIVE_FIRST_20_ENABLED=true
FIRST_TWENTY_ALLOW_LIVE=true

GOVERNANCE_ORDER_ENFORCEMENT=true
GOVERNANCE_CAUTION_BLOCK_ENTRIES=true
GOVERNANCE_MISSING_JOINT_BLOCKS=true
GOVERNANCE_STALE_JOINT_BLOCKS=true
GOVERNANCE_UNKNOWN_MODE_BLOCKS=true
GOVERNANCE_DEGRADED_INTEGRITY_BLOCKS=true
GOVERNANCE_JOINT_STALE_HOURS=48
